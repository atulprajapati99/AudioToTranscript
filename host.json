{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveDiagnosticsServer": true
    },
    "logLevel": {
      "AudioToTranscript": "Information",
      "Function": "Information",
      "Host.Results": "Error",
      "default": "Warning"
    }
  },
  "extensions": {
    "queues": {
      "maxDequeueCount": 5,
      "visibilityTimeout": "00:00:30",
      "batchSize": 1,
      "maxPollingInterval": "00:00:10"
    }
  }
}
